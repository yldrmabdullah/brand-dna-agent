# Brand DNA Agent — Environment Configuration
# Copy to .env and fill in your secrets. Never commit .env.

# ─── LLM Provider ────────────────────────────────────────────────────────────
# OpenRouter gives access to Anthropic, OpenAI, Google models through one key.
# Get yours at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: HTTP referrer and X-Title for OpenRouter analytics
OPENROUTER_REFERER=https://your-app.example.com
OPENROUTER_APP_TITLE=Brand DNA Agent

# ─── Model Selection (override defaults from config) ────────────────────────
# Vision + reasoning model used for synthesis & nuanced analysis.
BRAND_DNA_MODEL_PRIMARY=anthropic/claude-sonnet-4.5

# Cheap, fast model for high-volume tasks (image captioning, light classification).
BRAND_DNA_MODEL_FAST=google/gemini-2.5-flash

# Heavy synthesis model used for the final dossier composition.
BRAND_DNA_MODEL_SYNTHESIS=anthropic/claude-opus-4.1

# ─── Runtime Behavior ───────────────────────────────────────────────────────
BRAND_DNA_LOG_LEVEL=INFO
BRAND_DNA_LOG_FORMAT=json   # json | console
BRAND_DNA_OUTPUT_DIR=./outputs
BRAND_DNA_CACHE_DIR=./data/cache

# ─── Crawling Politeness ────────────────────────────────────────────────────
# Be a good citizen. These can be overridden per-brand in the YAML config.
BRAND_DNA_USER_AGENT=BrandDNA-Agent/0.1 (+contact@example.com)
BRAND_DNA_MAX_CONCURRENCY=4
BRAND_DNA_REQUEST_TIMEOUT_S=20
BRAND_DNA_DELAY_BETWEEN_REQUESTS_MS=400

# ─── Optional: Playwright (JS rendering) ────────────────────────────────────
# Disabled by default — Playwright is heavy. Enable per-brand if needed.
BRAND_DNA_ENABLE_PLAYWRIGHT=false

# ─── Optional: Hugging Face cache ───────────────────────────────────────────
# Where to cache FashionCLIP / OpenCLIP weights.
HF_HOME=./data/hf_cache
